{
	"name": "raptor",
	"private": true,
	"type": "module",
	"license": "AGPL-3.0-only",
	"packageManager": "bun@1.3.2",
	"engines": {
		"bun": ">=1.2"
	},
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"typecheck": "turbo run typecheck",
		"check": "biome check --write",
		"check:ci": "biome ci",
		"knip": "knip",
		"analyze": "bun run --filter @raptor/panel analyze",
		"dev:up": "docker compose -f infra/compose.yaml up -d --wait",
		"dev:down": "docker compose -f infra/compose.yaml down",
		"wings:build": "make -C apps/wings build",
		"wings:run": "make -C apps/wings run",
		"wings:test": "make -C apps/wings test"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"knip": "^6.16.1",
		"lefthook": "^2.1.9",
		"shadcn": "^4.11.0",
		"turbo": "^2.9.18"
	}
}
