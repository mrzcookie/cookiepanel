{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**"],
			"env": [
				"DATABASE_URL",
				"REDIS_URL",
				"AUTH_SECRET",
				"AUTH_URL",
				"AUTH_TRUSTED_ORIGINS",
				"AUTH_ADMIN_USER_IDS",
				"ENCRYPTION_KEY",
				"GITHUB_CLIENT_ID",
				"GITHUB_CLIENT_SECRET",
				"GOOGLE_CLIENT_ID",
				"GOOGLE_CLIENT_SECRET",
				"RESEND_API_KEY",
				"EMAIL_FROM",
				"POLAR_ACCESS_TOKEN",
				"POLAR_WEBHOOK_SECRET",
				"POLAR_SERVER",
				"POLAR_NODE_PRODUCT_ID",
				"CLOUDFLARE_API_TOKEN",
				"CLOUDFLARE_ZONE_ID",
				"VITE_NODES_DOMAIN",
				"DAEMON_LATEST_VERSION",
				"DAEMON_RELEASE_BASE_URL",
				"S3_ENDPOINT",
				"S3_REGION",
				"S3_BUCKET",
				"S3_ACCESS_KEY_ID",
				"S3_SECRET_ACCESS_KEY",
				"S3_PUBLIC_URL",
				"SKIP_ENV_VALIDATION"
			]
		},
		"typecheck": {}
	}
}
