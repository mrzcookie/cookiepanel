{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignore": [".claude/**"],
	"ignoreExportsUsedInFile": true,
	"ignoreBinaries": ["make"],
	"ignoreDependencies": [
		"@fontsource-variable/hanken-grotesk",
		"@fontsource-variable/jetbrains-mono",
		"shadcn",
		"tailwindcss",
		"tw-animate-css",
		"lefthook"
	],
	"ignoreWorkspaces": ["apps/wings", "packages/contract"],
	"workspaces": {
		"apps/panel": {
			"entry": [
				"src/routes/**/*.tsx",
				"src/components/ui/**",
				"src/router.tsx",
				"src/start.ts",
				"src/server/env.ts",
				"src/server/db/index.ts",
				"src/server/nodes/index.ts",
				"src/server/activity/index.ts",
				"src/server/storage/index.ts",
				"src/server/user/index.ts",
				"src/lib/auth-client.ts"
			],
			"project": ["src/**/*.{ts,tsx}", "!src/routeTree.gen.ts"]
		}
	}
}
