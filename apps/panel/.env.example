# CookiePanel panel — environment.
#
# Copy to `.env` (gitignored) and fill in. These are server-only and validated
# at startup by `src/server/env.ts`; a missing/invalid required var stops boot.
# The Core vars' defaults below match the dev infra in compose.yaml — run
# `pnpm dev:up` to start Postgres + Redis, then generate the secrets.

# === Core (required) ===

# Postgres connection string (Drizzle). Matches compose.yaml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cookiepanel"

# Redis connection string (Better Auth secondary storage). Matches compose.yaml.
REDIS_URL="redis://localhost:6379"

# Better Auth signing secret.  Generate: openssl rand -base64 32
AUTH_SECRET=""

# Public base URL the app is served from (auth callbacks + magic links).
AUTH_URL="http://localhost:3000"

# AES-256-GCM key for sealing secrets at rest — 32 bytes, hex.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# === Auth extras (optional) ===
# Extra CSRF-trusted origins, comma-separated (baseURL is always trusted).
AUTH_TRUSTED_ORIGINS=""
# User ids to bootstrap as platform admins, comma-separated (seeds the first admin).
AUTH_ADMIN_USER_IDS=""

# === OAuth social providers (optional) ===
# A sign-in button appears only when a provider's id + secret are both set.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Email — magic links + org invitations (Resend) ===
RESEND_API_KEY=""
# From address; "Name <addr@host>" is allowed.
EMAIL_FROM="CookiePanel <noreply@example.com>"

# === Billing — Polar (optional) ===
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# sandbox | production
POLAR_SERVER="sandbox"
# Product id for the per-node subscription.
POLAR_NODE_PRODUCT_ID=""

# === Object storage — S3-compatible (optional; template icons + uploads) ===
# Cloudflare R2 / AWS S3 / MinIO. Omit S3_ENDPOINT for AWS S3.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public base URL the icons/uploads are served from.
S3_PUBLIC_URL=""
