# RaptorPanel panel — environment.
#
# Copy to `.env` (gitignored) and fill in. These are server-only and validated
# at startup by `src/server/env.ts`; a missing/invalid required var stops boot.
# The Core vars' defaults below match the dev infra in compose.yaml — run
# `pnpm dev:up` to start Postgres + Redis, then generate the secrets.

# === Core (required) ===

# Postgres connection string (Drizzle). Matches compose.yaml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raptorpanel"

# Redis connection string (Better Auth secondary storage). Matches compose.yaml.
REDIS_URL="redis://localhost:6379"

# Better Auth signing secret.  Generate: openssl rand -base64 32
AUTH_SECRET=""

# Public base URL the app is served from (auth callbacks + magic links).
AUTH_URL="http://localhost:3000"

# AES-256-GCM key for sealing secrets at rest — 32 bytes, hex.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# === Auth extras (optional) ===
# Extra CSRF-trusted origins, comma-separated (baseURL is always trusted).
AUTH_TRUSTED_ORIGINS=""
# User ids to bootstrap as platform admins, comma-separated (seeds the first admin).
AUTH_ADMIN_USER_IDS=""

# === OAuth social providers (optional) ===
# A sign-in button appears only when a provider's id + secret are both set.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Email — magic links + org invitations (Resend) ===
RESEND_API_KEY=""
# From address; "Name <addr@host>" is allowed.
EMAIL_FROM="RaptorPanel <noreply@example.com>"

# === Billing — Polar (optional) ===
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# sandbox | production
POLAR_SERVER="sandbox"
# Product id for the per-node subscription.
POLAR_NODE_PRODUCT_ID=""

# === Managed-node DNS (optional; the "RaptorPanel subdomain" path) ===
# Base domain managed nodes get a subdomain under: a node is reachable at
# <node-slug>.<this>. Non-secret public config (shown in the connect wizard and
# used to build the node's address), so it's a build-time VITE_ var, not a server
# secret. Defaults to nodes.raptorpanel.app when unset.
VITE_NODES_DOMAIN="nodes.raptorpanel.app"
# Cloudflare creds to auto-manage each managed node's subdomain A record (created
# at enrollment when the node's public IP is first seen; removed with the node).
# Both required for auto-DNS; absent = the operator points DNS themselves. The
# token needs Zone:DNS:Edit on the zone that owns VITE_NODES_DOMAIN's base domain.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# === Object storage — S3-compatible (optional; egg icons + uploads) ===
# Cloudflare R2 / AWS S3 / MinIO. The defaults below target the MinIO service in
# compose.yaml — run `pnpm dev:up`, which also provisions the bucket.
# Setting S3_ENDPOINT switches the client to path-style addressing (MinIO / R2);
# OMIT S3_ENDPOINT for real AWS S3 (which uses virtual-hosted–style URLs).
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="raptorpanel"
# Dev MinIO root credentials (match compose.yaml) — DEV ONLY, replace in production.
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
# Public base URL the icons/uploads are served from.
S3_PUBLIC_URL="http://localhost:9000/raptorpanel"
